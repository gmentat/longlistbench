# Copy this file to .env and fill in values.
#
# NOTE: These keys are only required if you want to rerun OCR or LLM evaluation.

# Google Gemini API key (for OCR + Gemini extraction)
GEMINI_API_KEY=

# OpenAI API key (for GPT-4o / GPT-5.2 extraction)
OPENAI_API_KEY=

# Anthropic API key (optional; only needed if you evaluate Claude)
ANTHROPIC_API_KEY=

# Optional: override the Gemini model ID used for the 'gemini' model key
GEMINI_MODEL_ID=gemini-2.5-flash

# Optional: evaluation parallelism controls
# LLB_PARALLEL_MODELS=1
# LLB_MODEL_WORKERS=3
# LLB_GEMINI_CHUNK_WORKERS=2
# LLB_OPENAI_CHUNK_WORKERS=4
# LLB_ANTHROPIC_CHUNK_WORKERS=2

# GPT-5.5 regimes (gpt55_oneshot / gpt55_chunked / gpt55_agent). Use OPENAI_API_KEY.
# GPT55_MODEL_ID=gpt-5.5                  # model id for one-shot + chunked GPT-5.5
# LLB_ONESHOT_MAX_OUTPUT_TOKENS=32000    # output budget for one whole-doc one-shot call

# Agentic regime (gpt55_agent): OpenAI Agents SDK + local Docker sandbox.
# Requires a running Docker daemon.
# GPT55_AGENT_MODEL_ID=gpt-5.5
# LLB_AGENT_SANDBOX_IMAGE=python:3.14-slim
# LLB_AGENT_MAX_TURNS=60
# LLB_AGENT_TRACE_DIR=.agent_runs/traces  # where per-run behavior+cost traces are written
# Agentic runs are slow — raise the per-doc timeout (default 1800s):
# LLB_EXTRACT_TIMEOUT_SECONDS=5400
# Cost-estimate rates (USD per 1M tokens) for the agent trace:
# LLB_AGENT_PRICE_INPUT_PER_1M=5.0
# LLB_AGENT_PRICE_CACHED_INPUT_PER_1M=0.5
# LLB_AGENT_PRICE_OUTPUT_PER_1M=30.0
