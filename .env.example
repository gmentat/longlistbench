# Copy this file to .env and fill in values.
#
# NOTE: These keys are only required if you want to rerun OCR or LLM evaluation.

# Google Gemini API key (for OCR, Gemini extraction, and optional policy text generation).
# VERTEX_AI_API_KEY is checked first when present; GEMINI_API_KEY remains supported.
VERTEX_AI_API_KEY=
GEMINI_API_KEY=

# OpenRouter key (optional; enables --ocr-engine openrouter for Gemini OCR)
OPENROUTER_API_KEY=
# OPENROUTER_OCR_MODEL=google/gemini-3.5-flash

# OpenAI API key (for GPT-4o / GPT-5.x extraction)
OPENAI_API_KEY=

# Anthropic API key (optional; only needed if you evaluate Claude)
ANTHROPIC_API_KEY=

# Optional: override the Gemini model ID used for the 'gemini' model key
GEMINI_MODEL_ID=gemini-3.1-pro-preview

# Optional: policy fixture generation. The default generator is offline/template.
# Set POLICY_TEXT_GENERATOR=gemini when you want Gemini-authored synthetic policy prose.
# POLICY_TEXT_GENERATOR=template
# POLICY_GEMINI_MODEL=gemini-3.1-pro-preview
# POLICY_GEMINI_THINKING_LEVEL=high

# Optional: evaluation parallelism controls
# LLB_PARALLEL_MODELS=1
# LLB_MODEL_WORKERS=3
# LLB_GEMINI_CHUNK_MAX_INPUT_TOKENS=12000
# LLB_GEMINI_CHUNK_WORKERS=2
# LLB_OPENAI_CHUNK_WORKERS=4
# LLB_ANTHROPIC_CHUNK_WORKERS=2

# GPT-5.5 regimes (gpt55_oneshot / gpt55_chunked / gpt55_agent). Use OPENAI_API_KEY.
# GPT55_MODEL_ID=gpt-5.5                  # model id for one-shot + chunked GPT-5.5
# LLB_ONESHOT_MAX_OUTPUT_TOKENS=128000   # one-shot output budget (default = model max)
# OpenAI client robustness (responses are streamed; the read timeout is an
# inactivity ceiling, not a generation cap — a healthy long stream is never cut):
# LLB_OPENAI_READ_TIMEOUT_SECONDS=180    # abort a stalled connection after N idle seconds
# LLB_OPENAI_MAX_RETRIES=2
# LLB_OPENAI_REASONING_EFFORT=low        # gpt-5.x/o-series reasoning effort (none/low/medium/high)

# Agentic regime (gpt55_agent): OpenAI Agents SDK + local Docker sandbox.
# Requires a running Docker daemon.
# GPT55_AGENT_MODEL_ID=gpt-5.5
# LLB_AGENT_REASONING_EFFORT=xhigh
# LLB_AGENT_VERBOSITY=high
# LLB_AGENT_SANDBOX_IMAGE=python:3.14-slim
# LLB_AGENT_MAX_TURNS=60
# Agentic runs are slow — raise the per-doc timeout (default 1800s):
# LLB_EXTRACT_TIMEOUT_SECONDS=5400

# Cost + traces (shared across ALL regimes). The SDK/API return token counts;
# cost (USD) is computed from these rates (defaults = GPT-5.5 standard).
# LLB_PRICE_INPUT_PER_1M=5.0
# LLB_PRICE_CACHED_INPUT_PER_1M=0.5
# LLB_PRICE_OUTPUT_PER_1M=30.0
# LLB_CAPTURE_TRACES=1                    # opt-in: write per-call / per-run debug traces
# LLB_TRACE_DIR=.traces                   # where traces are written when enabled
